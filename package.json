{
  "name": "bitecode-agentic-orchestrator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "wrangler dev --local --port 8790",
    "deploy": "wrangler deploy --keep-vars",
    "deploy:dev": "wrangler deploy --env development --keep-vars",
    "deploy:prod": "wrangler deploy --env production --keep-vars",
    "deploy:keepsecrets": "wrangler deploy --keep-vars",
    "deploy:dev:keepsecrets": "wrangler deploy --env development --keep-vars",
    "deploy:prod:keepsecrets": "wrangler deploy --env production --keep-vars"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.101.0"
  }
}
